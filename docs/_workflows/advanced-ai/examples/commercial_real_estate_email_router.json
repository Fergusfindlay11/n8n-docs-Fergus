      "parameters": {
        "functionCode": "const text = $json.text || $json.response || '';\nconst subject = `${$json.building?.fields?.BuildingName || 'Property'} \u2014 next steps & viewings`;\nreturn [{ json: { ...$json, autoReply: { subject, body: text }, logPayload: { ...$json.logPayload, IsAutoReply: true, Status: 'awaiting-reply', FollowUpDueAt: $json.autoReplyContext.followUpAt } } }];"
