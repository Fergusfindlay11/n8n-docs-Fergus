    {
      "parameters": {
        "functionCode": "const building = $json.building?.fields || {};\nconst from = ($json.from?.emailAddress?.address || '').toLowerCase();\nconst isExternal = !from.endsWith('@bbgrealestate.co.uk');\nconst hasHumanReply = ($json.body?.content || '').toLowerCase().includes('x-auto: true');\nconst template = building.AutoReplyTemplate || '';\nconst slaMinutes = building.SLA_Minutes || 120;\nconst followUpAt = new Date(Date.now() + 48 * 60 * 60 * 1000).toISOString();\nconst shouldAutoReply = isExternal && !hasHumanReply && template;\nreturn [{ json: { ...$json, autoReplyContext: { template, slaMinutes, followUpAt }, shouldAutoReply } }];"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
