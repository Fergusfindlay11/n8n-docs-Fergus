    },
    {
      "parameters": {
        "functionCode": "const staticData = getWorkflowStaticData('global');\nconst seen = new Set(staticData.seenIds || []);\nconst output = [];\nfor (const item of items) {\n  const id = item.json.internetMessageId || item.json.id;\n  if (!id) continue;\n  if (!seen.has(id)) {\n    seen.add(id);\n    output.push(item);\n  }\n}\nstaticData.seenIds = Array.from(seen).slice(-500);\nreturn output;"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        -420,
        -80
      ],
      "id": "f020db8d-9318-4d7f-9f10-5a7a0bd1a48e",
      "name": "Skip already seen"
    },
    {
      "parameters": {
        "functionCode": "const vipSenders = ($json.env?.vipSenders || '').split(',').map(s => s.trim().toLowerCase()).filter(Boolean);\nconst urgentKeywords = ['completion','exchange','stat dec','board approval','deadline'];\nconst marketplaceDomains = ['rightmove.co.uk','egpropertylink.com','onthemarket.com'];\nconst brochureHints = ['brochure','investment memorandum','info pack','marketing deck'];\n\nreturn items.map(item => {\n  const data = item.json;\n  const fromAddress = (data.from?.emailAddress?.address || '').toLowerCase();\n  const domain = fromAddress.split('@')[1] || '';\n  const subject = (data.subject || '').toLowerCase();\n  const preview = ((data.bodyPreview || '') + ' ' + (data.body?.content || '')).toLowerCase();\n\n  let routing = 'Ambiguous';\n  let reason = 'Needs LLM review';\n  const notes = [];\n\n  if (vipSenders.includes(fromAddress)) {\n    routing = 'Instant';\n    reason = 'VIP sender';\n    notes.push('vip');\n  } else if (urgentKeywords.some(keyword => subject.includes(keyword) || preview.includes(keyword))) {\n    routing = 'Instant';\n    reason = 'Urgent keyword';\n    notes.push('urgent');\n  } else if (marketplaceDomains.some(dom => domain.endsWith(dom))) {\n    routing = 'Task';\n    reason = 'Marketplace lead';\n    notes.push('marketplace');\n  } else if (/\\b(please (confirm|review|sign|quote|schedule|revert|provide))\\b/.test(preview)) {\n    routing = 'Task';\n    reason = 'Explicit request detected';\n  } else if (subject.includes('newsletter') || preview.includes('unsubscribe')) {\n    routing = 'Sweep';\n    reason = 'Likely marketing';\n  }\n\n  const brochureType = brochureHints.some(h => preview.includes(h)) ? (subject.includes('investment') ? 'Investment' : 'Marketing') : undefined;\n\n  return {\n    json: {\n      ...data,\n      routing,\n      reason,\n      notes,\n      brochureType,\n      receivedDateTime: data.receivedDateTime,\n      needsLLM: routing === 'Ambiguous'\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        -200,
        -80
      ],
      "id": "5157f93a-19ac-4316-9b65-0c6e2e2a6540",
      "name": "Apply fast routing rules"
