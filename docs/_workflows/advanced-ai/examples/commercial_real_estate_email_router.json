    {
      "parameters": {
        "functionCode": "const text = ($json.subject || '') + ' ' + ($json.bodyPreview || '');\nconst postcodeMatch = text.match(/\\b[A-Z]{1,2}\\d[A-Z0-9]? ?\\d[A-Z]{2}\\b/i);\nconst aliases = ($json.notes || []).concat(($json.brochureType ? [$json.brochureType] : []));\nreturn [{\n  json: {\n    ...$json,\n    lookup: {\n      postcode: postcodeMatch ? postcodeMatch[0].toUpperCase() : '',\n      tokens: text.toLowerCase().split(/[^a-z0-9]+/).filter(Boolean).slice(0, 25),\n      aliases\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        1400,
        120
      ],
      "id": "a3656ab8-18b4-4ff7-92c0-0f67e03ba0c1",
      "name": "Prepare project lookup"
    },
    {
      "parameters": {
        "operation": "list",
        "application": "airtable",
        "id": "Buildings",
        "options": {
          "view": "Grid view",
          "filterByFormula": "={{$json.lookup.postcode ? `SEARCH(\"${$json.lookup.postcode}\", {Postcode})` : ''}}"
        }
      },
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 4,
      "position": [
        1620,
        120
      ],
      "id": "f69a727f-68f3-4b29-9b55-3c51cf08c84f",
      "name": "Fetch candidate buildings"
    },
    {
      "parameters": {
        "functionCode": "const candidates = items[0]?.json?.records || [];\nconst tokens = new Set(($input.item.json.lookup?.tokens || []));\nconst aliasHitsRequired = $json.lookup.postcode ? 1 : 2;\nlet best;\nfor (const record of candidates) {\n  const fields = record.fields || {};\n  const aliasList = (fields.Aliases || []).map(a => a.toLowerCase());\n  const hits = aliasList.filter(a => tokens.has(a)).length;\n  if (($json.lookup.postcode && fields.Postcode === $json.lookup.postcode) || hits >= aliasHitsRequired) {\n    best = { id: record.id, fields };\n    break;\n  }\n}\nreturn [{ json: { ...$json, building: best || null } }];"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
