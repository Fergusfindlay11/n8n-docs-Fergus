        "messages": {
          "message": [
            {
              "id": "53150a50-17c1-4f9b-9149-e3a2f3ff2577",
              "text": "Role: Classify an email for a UK commercial real estate broker.\\nLabels: Instant, Task, Sweep.\\nRules:\\n- Instant: VIP sender or urgent/commercial deadlines (completion, exchange, stat dec, board approval).\\n- Task: explicit ask (please confirm/provide/review/sign/quote/schedule/revert).\\n- Sweep: FYI/newsletters/marketing with no ask.\\nOutput pure JSON: {\"routing\":\"Instant|Task|Sweep\",\"reason\":\"...\"}",
              "type": "system"
            },
            {
              "id": "22d9e1db-e028-410d-b5ae-a82d393c2754",
              "text": "Classify this email:\\nSubject: {{$json.subject}}\\nFrom: {{$json.from.emailAddress.name}} <{{$json.from.emailAddress.address}}>\\nPreview: {{$json.bodyPreview}}",
              "type": "human"
            }
          ]
        },
        "options": {
          "temperature": 0
        }
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [
        260,
        -240
      ],
      "id": "2b44c799-401b-4cc0-8d46-04db8571fb4a",
      "name": "LLM classifier"
    },
    {
      "parameters": {
        "functionCode": "const raw = $json.text || $json.response || $json.content || $json.output || '';\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  throw new Error('LLM returned non-JSON: ' + raw);\n}\nreturn [{ json: { ...$json, ...parsed, needsLLM: false } }];"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        460,
        -240
